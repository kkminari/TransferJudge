# ============================================================
# 환경 변수 (API 키 등 민감 정보)
# ============================================================
.env
.env.local

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/

# ============================================================
# 대용량 raw 데이터 (HuggingFace Hub로 동기화)
# 본 연구의 사전 처리된 metadata는 사이즈가 커서 git LFS도 비효율
# Mac에서 upload_data_to_hub.py → RunPod에서 download_data_runpod.py
# ============================================================
data/books_meta_filtered.parquet
data/books_meta_filtered_v1_noauthor.parquet
data/movies_meta_filtered.parquet
.cache/
hf_cache/

# 백업 v1 파일 중 큰 것만 제외 (작은 백업은 push 유지)
# (작은 백업: data/*_users_pre_*.parquet, teacher_train_main_pre_*.jsonl 등은 포함)

# ============================================================
# 모델 체크포인트 (RunPod persistent volume 또는 HuggingFace Hub)
# Qwen3-14B + QLoRA adapter = ~50MB → HF Hub로 동기화
# 학습 메트릭만 예외로 git에 포함 (작은 JSON, 논문 분석용)
# ============================================================
checkpoints/*/*
!checkpoints/*/trainer_state.json
!checkpoints/*/training_args.bin
# 주의: 기존 'checkpoints/' 패턴은 부모 디렉토리 자체를 ignore해 위 negation이
# 무력화됨 (git docs: parent가 ignore면 child 재포함 불가). 'checkpoints/*/*'로 변경:
# 'checkpoints/judge_v1/' 자체는 추적하지 않지만 ignore되지도 않아 negation 동작.
# 주의: results/ (Phase 4·5 평가 결과)는 git에 push (작은 JSON·CSV)
# 큰 임시 파일이 results/에 생기면 개별 ignore 추가

# ============================================================
# 학습/추론 로그
# ============================================================
logs/
*.log

# ============================================================
# Pilot Study 완료 산출물 (이미 결과는 Pilot_Study_Report.md에 정리됨)
# ============================================================
pilot_outputs/

# ============================================================
# Teacher 중간 출력 디렉토리 (있다면)
# 최종 학습 데이터는 data/teacher_train.jsonl, teacher_val.jsonl로 별도 관리
# ============================================================
teacher_outputs/

# ============================================================
# OS / IDE
# ============================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# ============================================================
# Jupyter
# ============================================================
.ipynb_checkpoints/

# ============================================================
# 본 연구와 무관한 파일 (다른 과목·툴)
# ============================================================
.claude/
case_study03_*
case_study03_pages/
2026_case_study03_*
fill_epic_discussion.py

# ============================================================
# /tmp 작업 산출물 (임시)
# ============================================================
/tmp_local/

# ============================================================
# 주의: 다음은 GitHub로 push해야 함 (RunPod에서 필요)
# - profiler_outputs/         Phase 1 결과 (~50MB)
# - data/teacher_*.jsonl      Phase 2 결과 (~10MB)
# - data/*_users.parquet      작은 분할 데이터
# - data/*_reviews_filtered.parquet  리뷰 데이터 (작음)
# - results/                  Phase 4~5 결과
# ============================================================
